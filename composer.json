{
    "name": "porthd/sitemasterdata",
    "description": "Make website master data available as CKEditor variables",
    "type": "typo3-cms-extension",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "porthd"
        }
    ],
    "require": {
        "typo3/cms-core": "^14.3"
    },
    "require-dev": {
        "typo3/testing-framework": "^9.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "porthd\\sitemasterdata\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "porthd\\sitemasterdata\\Tests\\": "Tests/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "sitemasterdata"
        }
    }
}
